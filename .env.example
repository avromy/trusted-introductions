NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key
SUPABASE_STORAGE_RESUME_BUCKET=private-resumes

# Error tracking: development captures in memory; production defaults to disabled when unset.
ERROR_TRACKING_PROVIDER=development
