# Application
APP_ENV=development
APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/trusted_introductions

# Authentication
AUTH_SECRET=replace-me
AUTH_PROVIDER=

# Email
EMAIL_FROM=no-reply@example.org
EMAIL_PROVIDER=
EMAIL_API_KEY=

# Feature Flags
FEATURE_PUBLIC_MEET_PAGES=false
FEATURE_AI_SUMMARIES=false
FEATURE_MATCHING_ENGINE=false

# Observability
LOG_LEVEL=info
SENTRY_DSN=
